{% extends 'base.html.twig' %}

{% block title %}Secure Checkout - ADDmeCART{% endblock %}

{% block body %}
<div class="container" style="background-color: #FFFFFF; padding: 40px; margin-top: 20px; border: 1px solid #ddd; border-radius: 8px;">
    
    <h2 style="color: #333;">Checkout Summary</h2>
    <hr>

    {# Error messages for wrong PINs or 300-item limit #}
    {% for message in app.flashes('error') %}
        <div style="color: red; padding: 10px; background-color: #ffe6e6; border: 1px solid red; margin-bottom: 15px; border-radius: 4px;">
            {{ message }}
        </div>
    {% endfor %}

    <div class="order-details" style="margin-bottom: 30px; padding: 20px; background-color: #f9f9f9; border-radius: 5px;">
        <p><strong>Total Items:</strong> 10</p>
        <p><strong>Grand Total:</strong> ₱999.99</p>
    </div>

    <button onclick="document.getElementById('pinModal').style.display='block'" 
            style="background-color: #0056b3; color: white; padding: 12px 24px; border: none; cursor: pointer; border-radius: 5px; font-weight: bold;">
        Proceed to Secure Payment
    </button>
</div>

<div id="pinModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.75); z-index: 1000;">
    
    <div style="background-color: #FFFFFF; width: 350px; margin: 10% auto; padding: 30px; text-align: center; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.3);">
        
        <h3 style="margin-top: 0; color: #333;">Security Verification</h3>
        <p style="color: #666; font-size: 14px;">Enter your 4-Digit PIN to authorize this transaction via GCash.</p>
        
        <form action="{{ path('app_checkout_process') }}" method="POST">
            <input type="password" name="security_pin" maxlength="4" pattern="\d{4}" required placeholder="****" 
                   style="text-align: center; font-size: 32px; width: 140px; letter-spacing: 12px; margin: 20px 0; padding: 10px; border: 2px solid #ccc; border-radius: 5px;">
            <br>
            
            <button type="button" onclick="document.getElementById('pinModal').style.display='none'" 
                    style="background-color: #e0e0e0; color: #333; padding: 10px 15px; border: none; cursor: pointer; border-radius: 5px; margin-right: 10px;">
                Cancel
            </button>
            <button type="submit" 
                    style="background-color: #28a745; color: white; padding: 10px 20px; border: none; cursor: pointer; border-radius: 5px; font-weight: bold;">
                Confirm Payment
            </button>
        </form>
    </div>
</div>
{% endblock %}