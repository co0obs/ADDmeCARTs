{% extends 'base.html.twig' %}

{% block title %}Register - ADDmeCART{% endblock %}

{% block body %}
<div style="max-width: 550px; margin: 50px auto; padding: 30px; border: 1px solid #eaeaea; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); background: white;">
    <h1 style="text-align: center; color: #0056b3; margin-top: 0; font-size: 2.2rem;">Create Account</h1>

    {# Display any global form errors #}
    {{ form_errors(registrationForm) }}

    {{ form_start(registrationForm) }}
        
        {# Side-by-side First and Last Name #}
        <div style="display: flex; gap: 15px; margin-bottom: 15px;">
            <div style="flex: 1;">
                {{ form_row(registrationForm.firstName, {'attr': {'style': 'width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;'}}) }}
            </div>
            <div style="flex: 1;">
                {{ form_row(registrationForm.lastName, {'attr': {'style': 'width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;'}}) }}
            </div>
        </div>

        <div style="margin-bottom: 15px;">
            {{ form_row(registrationForm.email, {'attr': {'style': 'width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;'}}) }}
        </div>

        {# Highlighted Role Dropdown #}
        <div style="background-color: #f5f7ff; padding: 20px; border: 1px solid #0056b3; border-radius: 6px; margin: 25px 0;">
            {{ form_row(registrationForm.accountType, {
                'attr': {'style': 'width: 100%; padding: 10px; border-radius: 4px; font-weight: bold; cursor: pointer;'},
                'label_attr': {'style': 'font-weight: bold; color: #0056b3;'}
            }) }}
        </div>

        <div style="margin-bottom: 15px;">
            {{ form_row(registrationForm.securityPin, {'attr': {'style': 'width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;', 'placeholder': 'e.g. 1234'}}) }}
        </div>

        <div style="margin-bottom: 20px;">
            {{ form_row(registrationForm.plainPassword, {
                'label': 'Password',
                'attr': {'style': 'width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;'}
            }) }}
        </div>

        <div style="margin-bottom: 25px; display: flex; align-items: center; gap: 10px;">
            {{ form_row(registrationForm.agreeTerms) }}
        </div>

        <button type="submit" style="width: 100%; padding: 12px; background-color: #0056b3; color: white; font-size: 1.1em; font-weight: bold; border: none; border-radius: 6px; cursor: pointer; transition: background 0.2s;">
            Register Securely
        </button>
        
    {{ form_end(registrationForm) }}
</div>
{% endblock %}